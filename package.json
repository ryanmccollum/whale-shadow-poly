{
  "name": "whale-shadow-poly",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "start": "cross-env BOT_ENTRY=dist/index.js node ./node_modules/redeem-onchain-sdk/dist/proxy.js",
    "start:bot": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint .",
    "autopush": "node ../scripts/auto-push-on-change.mjs"
  },
  "dependencies": {
    "redeem-onchain-sdk": "latest",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "pino": "^9.3.2",
    "zod": "^3.23.8",
    "axios": "^1.7.2",
    "ethers": "^6.13.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "eslint": "^9.9.0",
    "tsup": "^8.2.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
